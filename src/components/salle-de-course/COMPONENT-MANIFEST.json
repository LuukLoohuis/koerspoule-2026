  "responsive_16x9": {
    "$comment": "Posities als CSS-grid; px-vrij. Breakpoint lg=1024: sidebar zichtbaar; daaronder verborgen (decoratie).",
    "grid": {
      "desktop": {
        "columns": "minmax(0,1fr) 240px",
        "rows": "auto auto auto auto",
        "areas": [
          "titlebar titlebar",
          "teamcard sidebar",
          "tableau  sidebar",
          "details  sidebar",
          "footer   footer"
        ]
      },
      "mobile": {
        "columns": "1fr",
        "areas": ["titlebar", "teamcard", "tableau", "details", "footer"],
        "notes": "sidebar hidden; KpiCards 2-koloms; ScoreFlip size kleiner; FooterBar wraps"
      }
    },
    "components": [
      { "component_name": "TitleBar", "grid_area": "titlebar" },
      { "component_name": "TeamCard + ScoreFlip", "grid_area": "teamcard", "layout": "flex: kop links, flip rechts" },
      { "component_name": "TableauDeBord (6× KpiCard)", "grid_area": "tableau", "layout": "grid-cols-2 md:grid-cols-3 gap-2" },
      { "component_name": "DetailStrip", "grid_area": "details", "layout": "grid-cols-2 md:grid-cols-4 divide-x" },
      { "component_name": "RadioSidebar (LiveClock, Grille, Tuner, Telemetry, ControlBox, Mic)", "grid_area": "sidebar", "visibility": "hidden lg:flex", "a11y": "aria-hidden, pointer-events-none" },
      { "component_name": "FooterBar", "grid_area": "footer", "layout": "flex wrap, mono labels" }
    ]
  }
